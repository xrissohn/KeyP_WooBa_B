{
  "name": "interest-radar-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "start:api": "APP_ROLE=api node --env-file-if-exists=.env --import tsx src/index.ts",
    "start:worker": "APP_ROLE=worker node --env-file-if-exists=.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/index.ts' --test-coverage-lines=85 --test-coverage-branches=70 --test-coverage-functions=75 test/**/*.test.ts",
    "ci": "pnpm typecheck && pnpm build && pnpm test:coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5",
    "fastify": "^5.4.0",
    "firebase-admin": "^13.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "description": "Open-source, cost-aware AI interest radar with multi-source collection, relevance review, cursor feeds, and push delivery.",
  "license": "MIT",
  "author": "KeyP contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xrissohn/KeyP_WooBa_B.git"
  },
  "bugs": {
    "url": "https://github.com/xrissohn/KeyP_WooBa_B/issues"
  },
  "homepage": "https://github.com/xrissohn/KeyP_WooBa_B#readme",
  "keywords": [
    "interest-monitoring",
    "ai-agent",
    "information-retrieval",
    "rss",
    "notifications",
    "fastify",
    "openapi",
    "firebase",
    "kotlin-multiplatform"
  ]
}
