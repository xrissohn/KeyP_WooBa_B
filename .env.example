PORT=3000
HOST=127.0.0.1
DATABASE_PATH=./data/radar.sqlite
POLL_INTERVAL_SECONDS=60
WORKER_TICK_SECONDS=5
WORKER_CONCURRENCY=5

# Provider-wide safety budgets. 0 means unlimited. Identical source plans share a cached fetch.
NAVER_MIN_INTERVAL_SECONDS=60
NAVER_DAILY_BUDGET=24000
NAVER_BUDGET_TIME_ZONE=Asia/Seoul
GOOGLE_MIN_INTERVAL_SECONDS=900
GOOGLE_DAILY_BUDGET=90
GOOGLE_BUDGET_TIME_ZONE=America/Los_Angeles
SARAMIN_MIN_INTERVAL_SECONDS=300
SARAMIN_DAILY_BUDGET=450
SARAMIN_BUDGET_TIME_ZONE=Asia/Seoul
RSS_MIN_INTERVAL_SECONDS=300
RSS_DAILY_BUDGET=0
RSS_BUDGET_TIME_ZONE=UTC
WORKER_CONCURRENCY=5

# OpenAI-compatible Chat Completions endpoint. Without these, a deterministic planner is used.
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCH_BASE_URL=https://openapi.naver.com/v1/search

GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

SARAMIN_ACCESS_KEY=

# Use Application Default Credentials, or provide a service account JSON string.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated public RSS URLs available to the planner.
DEFAULT_RSS_FEEDS=
