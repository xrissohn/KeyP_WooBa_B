PORT=3000
HOST=127.0.0.1
DATABASE_PATH=./data/radar.sqlite
POLL_INTERVAL_SECONDS=60
WORKER_TICK_SECONDS=5
WORKER_CONCURRENCY=5

# OpenAI-compatible Chat Completions endpoint. Without these, a deterministic planner is used.
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCH_BASE_URL=https://openapi.naver.com/v1/search

GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

SARAMIN_ACCESS_KEY=

# Use Application Default Credentials, or provide a service account JSON string.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated public RSS URLs available to the planner.
DEFAULT_RSS_FEEDS=
