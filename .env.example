PORT=3000
HOST=127.0.0.1
APP_ROLE=all
DATABASE_PATH=./data/radar.sqlite
POLL_INTERVAL_SECONDS=60
WORKER_TICK_SECONDS=5
WORKER_CONCURRENCY=5
SCHEDULER_LEASE_SECONDS=300

# Provider-wide safety budgets. 0 means unlimited. Identical source plans share a cached fetch.
NAVER_MIN_INTERVAL_SECONDS=60
NAVER_DAILY_BUDGET=24000
NAVER_BUDGET_TIME_ZONE=Asia/Seoul
RSS_MIN_INTERVAL_SECONDS=300
RSS_DAILY_BUDGET=0
RSS_BUDGET_TIME_ZONE=UTC
AI_SEARCH_MIN_INTERVAL_SECONDS=300
AI_SEARCH_DAILY_BUDGET=500
AI_SEARCH_BUDGET_TIME_ZONE=UTC
SERPAPI_MIN_INTERVAL_SECONDS=300
SERPAPI_DAILY_BUDGET=100
SERPAPI_BUDGET_TIME_ZONE=UTC
YOUTUBE_MIN_INTERVAL_SECONDS=300
YOUTUBE_DAILY_BUDGET=100
YOUTUBE_BUDGET_TIME_ZONE=America/Los_Angeles

# OpenAI-compatible Chat Completions endpoint. Without these, a deterministic planner is used.
AI_API_URL=https://api.openai.com/v1/responses
AI_API_KEY=
AI_MODEL=gpt-5.6
AI_REVIEW_ENABLED=true
AI_REVIEW_REQUIRED=true
AI_RELEVANCE_THRESHOLD=55
AI_CREDIBILITY_THRESHOLD=40
AI_REVIEW_BATCH_SIZE=15

# Grounded AI search. Engines are tried in order and stop after the first successful call.
AI_SEARCH_ENGINES=perplexity,gemini,xai
PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai/v1/sonar
PERPLEXITY_MODEL=sonar
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-flash
XAI_API_KEY=
XAI_API_URL=https://api.x.ai/v1/responses
XAI_MODEL=grok-4.5

SERPAPI_API_KEY=
SERPAPI_API_URL=https://serpapi.com/search.json
YOUTUBE_API_KEY=
YOUTUBE_API_URL=https://www.googleapis.com/youtube/v3/search

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCH_BASE_URL=https://openapi.naver.com/v1/search

X_BEARER_TOKEN=
X_SEARCH_BASE_URL=https://api.x.com/2/tweets/search/recent
X_MIN_INTERVAL_SECONDS=60
X_DAILY_BUDGET=450
X_BUDGET_TIME_ZONE=UTC

# Use Application Default Credentials, or provide a Firebase Admin service account.
# google-services.json is for the Android client and cannot send FCM from the backend.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
# Temporarily disabled. Enable both when per-installation isolation is restored.
FIREBASE_APP_CHECK_ENFORCED=false
FIREBASE_INSTALLATION_IDENTITY_ENABLED=false
ANONYMOUS_INSTALLATION_ID=temporary-anonymous-installation

# Comma-separated public RSS URLs available to the planner.
DEFAULT_RSS_FEEDS=
